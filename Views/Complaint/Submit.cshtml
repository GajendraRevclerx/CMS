@{
    ViewData["Title"] = "Register & Submit Complaint";
    bool isLoggedIn = User.Identity != null && User.Identity.IsAuthenticated && !User.IsInRole("Admin") && !User.IsInRole("Officer");
}

<style>
  :root {
    --primary: #2563eb;
    --primary-hover: #1d4ed8;
    --saffron: #f97316;
    --saffron-hover: #ea580c;
    --green: #10b981;
    --bg-color: #f8fafc;
    --card-bg: #ffffff;
    --text-main: #1e293b;
    --text-muted: #64748b;
    --border-color: #e2e8f0;
    --danger: #ef4444;
  }
  
  .reg-page * { box-sizing: border-box; font-family: 'Segoe UI', system-ui, -apple-system, sans-serif; }

  .reg-page {
    max-width: 920px;
    margin: 36px auto;
    padding: 0;
    color: var(--text-main);
  }

  .page-banner {
    background: linear-gradient(135deg, #1e3a8a 0%, #2563eb 100%);
    color: white;
    padding: 28px 35px;
    border-radius: 16px 16px 0 0;
    display: flex;
    align-items: center;
    gap: 20px;
  }
  .page-banner .icon { font-size: 42px; }
  .page-banner h2 { margin: 0 0 5px; font-size: 24px; font-weight: 700; }
  .page-banner p  { margin: 0; font-size: 14px; opacity: 0.85; }

  .reg-body { background: white; border-radius: 0 0 16px 16px; box-shadow: 0 10px 30px rgba(0,0,0,0.08); padding: 32px 35px; }

  .dynamic-complaint-no {
    background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%);
    border-left: 5px solid var(--primary);
    padding: 14px 20px;
    border-radius: 8px;
    margin-bottom: 26px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    box-shadow: 0 2px 8px rgba(37, 99, 235, 0.08);
  }
  .dynamic-complaint-no h5 { margin: 0; font-size: 16px; color: var(--text-main); display: flex; align-items: center; gap: 10px; font-weight: 600; }
  .dynamic-complaint-no .badge-status { background: var(--primary); color: white; padding: 4px 14px; border-radius: 20px; font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; }

  .section-divider { display: flex; align-items: center; gap: 14px; margin: 28px 0 20px; }
  .section-divider .step-badge { background: var(--primary); color: white; width: 28px; height: 28px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 13px; font-weight: 700; flex-shrink: 0; }
  .section-divider span { font-size: 16px; font-weight: 700; color: var(--primary); }
  .section-divider::after { content:''; flex:1; height:1px; background:var(--border-color); }

  .form-card {
    background: #f8fafc;
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 22px;
    margin-bottom: 22px;
  }

  .form-grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; }
  .form-grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 18px; }

  .form-group { display: flex; flex-direction: column; gap: 7px; }
  .form-group.span-2 { grid-column: span 2; }
  .form-group.span-3 { grid-column: span 3; }
  .form-group label { font-weight: 600; font-size: 13.5px; color: var(--text-main); }
  .required { color: var(--danger); }

  .reg-page input[type="text"],
  .reg-page input[type="email"],
  .reg-page input[type="password"],
  .reg-page input[type="date"],
  .reg-page select,
  .reg-page textarea {
    width: 100%; padding: 11px 14px;
    border: 1.5px solid var(--border-color);
    border-radius: 8px; font-size: 14.5px;
    transition: all 0.2s ease; background: white; color: #334155;
  }
  .reg-page input:focus, .reg-page select:focus, .reg-page textarea:focus {
    outline: none; border-color: var(--primary); box-shadow: 0 0 0 3px rgba(37,99,235,0.1);
  }
  .reg-page input[readonly] { background: #e2e8f0 !important; color: #64748b; cursor: default; border-color: transparent; }

  .form-note { font-size: 12px; color: var(--text-muted); margin-top: -3px; }
  .upload-area { border: 2px dashed #cbd5e1; border-radius: 10px; padding: 28px; text-align: center; cursor: pointer; background: #f8fafc; transition: all 0.3s ease; }
  .upload-area:hover { border-color: var(--primary); background: #eff6ff; }

  .form-actions { display: flex; gap: 15px; justify-content: flex-end; padding-top: 22px; border-top: 2px solid var(--border-color); margin-top: 10px; }

  .btn-submit {
    background: var(--saffron); color: white; border: none; padding: 14px 40px;
    border-radius: 8px; font-size: 16px; font-weight: 700; cursor: pointer;
    transition: all 0.2s ease; box-shadow: 0 4px 12px rgba(249,115,22,0.25);
  }
  .btn-submit:hover { background: var(--saffron-hover); transform: translateY(-2px); box-shadow: 0 6px 16px rgba(249,115,22,0.35); }
  .btn-cancel { background: white; color: var(--text-main); border: 1.5px solid #cbd5e1; padding: 14px 26px; border-radius: 8px; font-size: 15px; font-weight: 600; cursor: pointer; transition: all 0.2s ease; }
  .btn-cancel:hover { background: #f1f5f9; }

  .already-login-note { background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 8px; padding: 12px 16px; font-size: 13.5px; color: #166534; margin-bottom: 22px; display: flex; align-items: center; gap: 10px; }

  .pass-strength { height: 4px; border-radius: 2px; margin-top: 6px; background: #e2e8f0; transition: all 0.3s; }

  @@media (max-width: 768px) {
    .form-grid-2, .form-grid-3 { grid-template-columns: 1fr; }
    .form-group.span-2, .form-group.span-3 { grid-column: span 1; }
    .reg-body { padding: 20px; }
    .dynamic-complaint-no { flex-direction: column; align-items: flex-start; gap: 8px; }
  }
</style>

<div class="container-fluid mt-3 mb-5">
  <div id="alertMessage"></div>

  <div class="reg-page">
    <!-- Banner -->
    <div class="page-banner">
      <div class="icon">📋</div>
      <div>
        <h2>Register & Submit Complaint</h2>
        <p>Fill in your details and complaint information below. Your account will be created automatically.</p>
      </div>
    </div>

    <div class="reg-body">
      <form id="complaintForm">

        <!-- Complaint No Preview -->
        <div class="dynamic-complaint-no">
          <h5>📌 Acknowledgement No:
            <span id="generatedComplaintNo" style="font-family:Consolas,monospace;letter-spacing:1px;color:var(--primary);font-weight:800;margin-left:6px;">Generating...</span>
            <input type="hidden" id="ComplaintNo">
          </h5>
          <span class="badge-status">New Draft</span>
        </div>

        @if (isLoggedIn)
        {
          <!-- Already logged in -->
          <div class="already-login-note">
            ✅ You are logged in as <strong>@User.Identity!.Name</strong> (@User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value). Your complaint will be filed under this account.
          </div>
        }
        else
        {
          <!-- SECTION 1: Citizen Details -->
          <div class="section-divider"><div class="step-badge">1</div><span>Your Details</span></div>
          <div class="form-card">
            <div class="form-grid-2">
              <div class="form-group">
                <label>Full Name <span class="required">*</span></label>
                <input type="text" id="FullName" placeholder="e.g. Ramesh Kumar" required>
              </div>
              <div class="form-group">
                <label>Mobile Number <span class="required">*</span></label>
                <input type="text" id="MobileNo" placeholder="10-digit number" maxlength="10" required>
                <div class="form-note">This will be your login ID. An account will be created automatically.</div>
              </div>
              <div class="form-group">
                <label>Email (Optional)</label>
                <input type="email" id="CitizenEmail" placeholder="your@email.com">
              </div>
              <div class="form-group">
                <label>Password <span class="required">*</span></label>
                <input type="password" id="Password" placeholder="Set a password for login" required>
                <div class="pass-strength" id="passStrength"></div>
                <div class="form-note">Minimum 6 characters. Used to log in and track your complaints.</div>
              </div>
            </div>
          </div>
        }

        <!-- SECTION 2: Location Details -->
        <div class="section-divider"><div class="step-badge">@(isLoggedIn ? "1" : "2")</div><span>Location Details</span></div>
        <div class="form-card">
          <div class="form-grid-3">
            <div class="form-group span-2">
              <label>House No. / Street <span class="required">*</span></label>
              <input type="text" id="Street" placeholder="e.g. H. No. 1024, Sector 22-B" required>
            </div>
            <div class="form-group">
              <label>Ward / Locality <span class="required">*</span></label>
              <input type="text" id="Locality" placeholder="e.g. Sector 22">
            </div>
            <div class="form-group">
              <label>City <span class="required">*</span></label>
              <select id="City" required><option value="">Loading...</option></select>
            </div>
            <div class="form-group">
              <label>PIN Code <span class="required">*</span></label>
              <input type="text" id="PinCode" placeholder="160022" maxlength="6">
            </div>
            <div class="form-group">
              <label>State <span class="required">*</span></label>
              <select id="State" required><option value="">Loading...</option></select>
            </div>
          </div>
        </div>

        <!-- SECTION 3: Complaint Details -->
        <div class="section-divider"><div class="step-badge">@(isLoggedIn ? "2" : "3")</div><span>Complaint Information</span></div>
        <div class="form-card">
          <div class="form-grid-2">
            <div class="form-group">
              <label>Complaint Title <span class="required">*</span></label>
              <input type="text" id="ComplaintTitle" placeholder="Brief title of the issue" required>
            </div>
            <div class="form-group">
              <label>Department Category <span class="required">*</span></label>
              <select id="Department" required>
                <option value="">Select Department</option>
              </select>
              <div class="form-note">Auto-detected from title — you can change it.</div>
            </div>
            <div class="form-group">
              <label>Source of Complaint <span class="required">*</span></label>
              <select id="Source" required>
                <option value="">— Select Source —</option>
                <option value="Mobile">Mobile</option>
                <option value="WhatsApp">WhatsApp</option>
              </select>
            </div>
            <div class="form-group">
              <label>Date of Incident <span class="required">*</span></label>
              <input type="date" id="incidentDate" required>
            </div>
            <div class="form-group span-2">
              <label>Complaint Site (Exact Location) <span class="required">*</span></label>
              <input type="text" id="Site" placeholder="e.g. Sector 22-B, near Pole No. 34, Opposite park" required>
            </div>
            <div class="form-group span-2">
              <label>Detailed Description <span class="required">*</span></label>
              <textarea id="Description" rows="5" minlength="10" placeholder="Describe the issue in detail (minimum 10 characters). Include the exact location, nature of the problem, and any previous action taken..." required></textarea>
              <div class="form-note d-flex justify-content-between">
                <span>Be as specific as possible for faster resolution.</span>
                <span id="descCount" style="color:red;font-weight:bold;">0 / 10 (Min)</span>
              </div>
            </div>
            <div class="form-group span-2">
              <label>Upload Evidence (Optional)</label>
              <div class="upload-area">
                <div style="font-size:28px;margin-bottom:8px;color:var(--primary);">📎</div>
                <p style="margin:0 0 4px;font-weight:600;color:var(--text-main);">Click to upload or drag &amp; drop</p>
                <small style="color:var(--text-muted);">Supported: JPG, PNG, MP4 (Max 10 MB)</small>
              </div>
            </div>
          </div>
        </div>

        <div class="form-actions">
          <button type="button" class="btn-cancel" onclick="window.history.back()">Cancel</button>
          <button type="submit" class="btn-submit" id="btnSubmit">Submit Complaint &rarr;</button>
        </div>
      </form>
    </div>
  </div>
</div>

@section Scripts {
  <script>
    $(document).ready(function () {
      // Set today's date
      document.getElementById('incidentDate').valueAsDate = new Date();

      // Load next sequence for preview
      var currentYear = new Date().getFullYear();
      $.ajax({ url: '/api/MasterData/next-sequence/complaint_seq', type: 'GET', success: function(res) {
        var nextSeq = (res.currentValue + 1).toString().padStart(5, '0');
        var preview = `${currentYear}/${nextSeq}`;
        $('#generatedComplaintNo').text(preview);
        $('#ComplaintNo').val(preview);
      }});

      // Load states
      $.ajax({ url: '/api/MasterData/states', type: 'GET', success: function(data) {
        var $s = $('#State').empty();
        $s.append('<option value="">— Select State —</option>');
        data.forEach(function(v) { $s.append($('<option>').val(v).text(v)); });
      }});

      // Load cities
      $.ajax({ url: '/api/MasterData/cities', type: 'GET', success: function(data) {
        var $c = $('#City').empty();
        $c.append('<option value="">— Select City —</option>');
        data.forEach(function(v) { $c.append($('<option>').val(v).text(v)); });
      }});

      // Load departments
      $.ajax({ url: '/api/MasterData/departments', type: 'GET', success: function(data) {
        var $d = $('#Department').empty();
        $d.append('<option value="">Select Department</option>');
        data.forEach(function(dept) { $d.append($('<option>').val(dept.code).text(dept.name)); });
      }});

      // Description character count (min 10)
      $('#Description').on('input', function () {
        var len = $(this).val().length;
        $('#descCount').text(len + ' / 10 (Min)').css('color', len < 10 ? 'red' : 'green');
      });

      // Password strength indicator
      $('#Password').on('input', function() {
        var len = $(this).val().length;
        var pct = Math.min(len / 10 * 100, 100);
        var clr = len < 4 ? '#ef4444' : len < 8 ? '#f59e0b' : '#10b981';
        $('#passStrength').css({ width: pct + '%', background: clr });
      });

      // Smart auto-detect department from title
      $('#ComplaintTitle').on('keyup', function () {
        var t = $(this).val().toLowerCase();
        var map = [
          { kw:['wire','electricity','spark','power','pole','light','transformer','voltage'], code:'ELE' },
          { kw:['water','leak','pipe','plumbing','drain','sewage','supply'], code:'WAT' },
          { kw:['garbage','trash','clean','sweep','waste','sanitation'], code:'SAN' },
          { kw:['road','pothole','street','footpath','highway','pavement'], code:'ROA' },
          { kw:['tree','garden','park','horticulture','plant','grass'], code:'HOR' },
          { kw:['health','hospital','dispensary','medicine','doctor'], code:'HEA' },
        ];
        for (var m of map) {
          if (m.kw.some(function(k){ return t.includes(k); })) {
            $('#Department').val(m.code);
            break;
          }
        }
        // Updates preview using the sequence already displayed
        var currentPreview = $('#generatedComplaintNo').text();
        // Just keep what's there if it was loaded, or re-calculate if needed.
        // For simplicity, since it's loaded on document.ready, we don't need to change anything here unless year changes.
      });

      // Form submit
      $('#complaintForm').on('submit', function (e) {
        e.preventDefault();

        var desc = $('#Description').val();
        if (desc.length < 10) {
          showAlert('danger', 'Description must be at least 10 characters long.');
          return;
        }

        var isLoggedIn = @Json.Serialize(isLoggedIn);

        var payload = {
          ComplaintTitle : $('#ComplaintTitle').val(),
          Description    : desc,
          Department     : $('#Department').val(),
          State          : $('#State').val(),
          City           : $('#City').val(),
          Street         : $('#Street').val(),
          Locality       : $('#Locality').val(),
          PinCode        : $('#PinCode').val(),
          Source         : $('#Source').val(),
          Site           : $('#Site').val(),
          IncidentDate   : $('#incidentDate').val()
        };

        if (!isLoggedIn) {
          payload.FullName = $('#FullName').val();
          payload.MobileNo = $('#MobileNo').val();
          payload.Password = $('#Password').val();
          payload.Email    = $('#CitizenEmail').val();

          if (!payload.FullName || !payload.MobileNo || !payload.Password) {
            showAlert('danger', 'Please fill in your Full Name, Mobile Number, and Password.');
            return;
          }
          if (payload.MobileNo.length !== 10 || isNaN(payload.MobileNo)) {
            showAlert('danger', 'Mobile number must be a 10-digit number.');
            return;
          }
        }

        $('#btnSubmit').prop('disabled', true).text('Submitting...');

        $.ajax({
          url         : '/Complaint/Submit',
          type        : 'POST',
          contentType : 'application/json',
          data        : JSON.stringify(payload),
          success     : function (res) {
            if (res.success) {
              showAlert('success',
                `<strong>✅ Complaint Submitted Successfully!</strong><br>
                 Your Acknowledgement Number: <strong style="font-family:monospace;">${res.complaintNo}</strong><br>
                 <small>Please save this number to track your complaint status.</small>
                 ${!isLoggedIn ? '<br><small style="color:#166534;">✅ Your account has been created. Use your Mobile No &amp; Password to login.</small>' : ''}`
              );
              document.getElementById('complaintForm').reset();
              document.getElementById('incidentDate').valueAsDate = new Date();
              $('#descCount').text('0 / 10 (Min)').css('color','red');
            } else {
              showAlert('danger', res.message || 'Submission failed.');
            }
          },
          error: function (xhr) {
            var msg = 'An error occurred while submitting the form.';
            try { msg = JSON.parse(xhr.responseText).message || msg; } catch(e) {}
            showAlert('danger', msg);
          },
          complete: function() {
            $('#btnSubmit').prop('disabled', false).text('Submit Complaint →');
          }
        });
      });

      function showAlert(type, html) {
        $('#alertMessage').html(
          `<div class="alert alert-${type} alert-dismissible fade show" role="alert">
             ${html}
             <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
           </div>`
        );
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }
    });
  </script>
}
