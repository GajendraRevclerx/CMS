@model CMS.Models.Complaint

@{
    ViewData["Title"] = "Submit Complaint";
}

<style>
  :root {
    --primary: #0f172a;
    --primary-hover: #1e293b;
    --accent: #4f46e5;
    --accent-hover: #4338ca;
    --bg-color: #f1f5f9;
    --card-bg: rgba(255, 255, 255, 0.95);
    --text-main: #0f172a;
    --text-muted: #64748b;
    --border-color: #e2e8f0;
    --danger: #ef4444;
  }

  .reg-page {
    max-width: 950px;
    margin: 60px auto;
    padding: 45px;
    background: var(--card-bg);
    backdrop-filter: blur(24px);
    border: 1px solid rgba(255,255,255,0.6);
    border-radius: 28px;
    box-shadow: 0 25px 50px -12px rgba(0,0,0,0.15), 0px 4px 6px -2px rgba(0,0,0,0.05);
    color: var(--text-main);
  }

  @@keyframes slideUp {
      to { transform: translateY(0); opacity: 1; }
  }

  .page-header-block {
    display: flex;
    align-items: center;
    gap: 24px;
    margin-bottom: 35px;
    padding-bottom: 30px;
    border-bottom: 2px solid #f1f5f9;
  }

  .page-header-block .icon {
    font-size: 48px;
    background: linear-gradient(135deg, #6366f1, #4f46e5);
    color: white;
    width: 80px;
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 20px;
    box-shadow: 0 10px 20px rgba(79, 70, 229, 0.3);
  }

  .page-header-block h2 {
    margin: 0 0 8px 0;
    color: var(--primary);
    font-size: 32px;
    font-weight: 800;
    letter-spacing: -0.5px;
  }

  .page-header-block p {
    margin: 0;
    color: var(--text-muted);
    font-size: 15px;
    line-height: 1.6;
    max-width: 600px;
  }

  .dynamic-complaint-no {
    background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
    border-left: 6px solid var(--accent);
    padding: 20px 24px;
    border-radius: 12px;
    margin-bottom: 30px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    box-shadow: 0 10px 15px -3px rgba(15, 23, 42, 0.3);
    color: white;
  }

  .dynamic-complaint-no h5 {
    margin: 0;
    font-size: 18px;
    color: #f8fafc;
    display: flex;
    align-items: center;
    gap: 12px;
    font-weight: 600;
  }

  .dynamic-complaint-no .badge-status {
    background: rgba(255,255,255,0.15);
    color: white;
    padding: 6px 16px;
    border-radius: 20px;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    backdrop-filter: blur(10px);
  }

  .form-card {
    background: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 20px;
    padding: 30px;
    margin-bottom: 30px;
    box-shadow: 0 4px 6px rgba(0,0,0,0.02);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .form-card:hover {
    box-shadow: 0 12px 24px rgba(0,0,0,0.06);
    border-color: #cbd5e1;
    transform: translateY(-2px);
  }

  .form-card-title {
    font-size: 19px;
    font-weight: 700;
    margin-bottom: 24px;
    padding-bottom: 16px;
    border-bottom: 1px solid #f1f5f9;
    display: flex;
    align-items: center;
    gap: 14px;
    color: var(--primary);
  }

  .form-card-title .badge {
    background: var(--accent);
    color: white;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 10px;
    font-size: 15px;
    font-weight: 800;
    box-shadow: 0 4px 8px rgba(79, 70, 229, 0.3);
  }

  .form-grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
  .form-grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 24px; }
  .form-group { display: flex; flex-direction: column; gap: 10px; }
  .form-group.span-2 { grid-column: span 2; }

  .form-group label {
    font-weight: 700;
    font-size: 13.5px;
    color: var(--primary);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .required { color: var(--accent); font-weight: 900; }

  .reg-page input[type="text"],
  .reg-page input[type="date"],
  .reg-page select,
  .reg-page textarea {
    width: 100%;
    padding: 14px 18px;
    border: 2px solid #f1f5f9;
    border-radius: 12px;
    font-size: 15px;
    font-weight: 500;
    transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
    background: #f8fafc;
    color: var(--primary);
  }

  .reg-page input:focus, .reg-page select:focus, .reg-page textarea:focus {
    outline: none;
    border-color: var(--accent);
    background: #ffffff;
    box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.15);
  }

  .form-note { font-size: 12px; color: var(--text-muted); font-weight: 500; margin-top: -2px; }

  .upload-area {
    border: 2px dashed #cbd5e1;
    border-radius: 16px;
    padding: 35px;
    text-align: center;
    cursor: pointer;
    background: #f8fafc;
    transition: all 0.3s ease;
  }

  .upload-area:hover {
    border-color: var(--accent);
    background: #eef2ff;
  }

  .upload-icon { font-size: 32px; margin-bottom: 12px; color: var(--accent); }
  .upload-area p { margin: 0 0 6px 0; font-weight: 700; color: var(--primary); }
  .upload-area small { color: var(--text-muted); font-weight: 500; }

  .form-actions {
    display: flex;
    gap: 16px;
    justify-content: flex-end;
    padding-top: 30px;
    border-top: 1px solid #e2e8f0;
  }

  .btn-primary-custom {
    background: linear-gradient(135deg, var(--accent), var(--accent-hover));
    color: white;
    border: none;
    padding: 16px 40px;
    border-radius: 12px;
    font-size: 16px;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.2s ease;
    box-shadow: 0 8px 16px rgba(79, 70, 229, 0.3);
    letter-spacing: 0.5px;
  }

  .btn-primary-custom:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 20px rgba(79, 70, 229, 0.4);
  }
  
  .btn-secondary-custom {
    background: white;
    color: var(--primary);
    border: 2px solid #cbd5e1;
    padding: 16px 32px;
    border-radius: 12px;
    font-size: 16px;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .btn-secondary-custom:hover {
    background: #f8fafc;
    border-color: #94a3b8;
  }

  @@media (max-width: 768px) {
    .form-grid-2, .form-grid-3 { grid-template-columns: 1fr; }
    .form-group.span-2 { grid-column: span 1; }
    .reg-page { padding: 25px; margin: 20px;}
  }
</style>

<div class="container mt-4 mb-5">
    <div class="row">
        <div class="col-12">

            
            <div class="reg-page">
                <form id="complaintForm" method="post">
                    <div class="page-header-block">
                        <div class="icon">📋</div>
                        <div>
                        <h2>Register New Complaint</h2>
                        <p>Submit your service request below. Your personal details are fetched securely from your account. Fields marked <span class="required">*</span> are mandatory.</p>
                        </div>
                    </div>

                    <div class="dynamic-complaint-no">
                        <h5>
                        📌 Complaint No: 
                        <span id="generatedComplaintNo" style="font-family: Consolas, monospace; letter-spacing: 1px; color: var(--primary); font-weight: 800; margin-left:8px;">Generating...</span>
                        <input type="hidden" id="ComplaintNo" name="ComplaintNo" />
                        </h5>    
                        <span class="badge-status">New Draft</span>
                    </div>

                    <!-- SECTION 1: Address Details -->
                    <div class="form-card">
                        <div class="form-card-title"><span class="badge">1</span> Location Details</div>
                        <div class="form-grid-2">
                             <div class="form-group span-2">
                                 <label>House No. / Street <span class="required">*</span></label>
                                 <input type="text" id="Street" name="Street" placeholder="e.g. H. No. 1024, Sector 22-B">
                             </div>
                             <div class="form-group span-2">
                                 <label>Ward / Locality <span class="required">*</span></label>
                                 <input type="text" id="Locality" name="Locality" placeholder="e.g. Sector 22">
                             </div>
                             <div class="form-group">
                                 <label asp-for="State">State <span class="required">*</span></label>
                                 <select asp-for="State" id="State" required>
                                     <option value="">Loading...</option>
                                 </select>
                             </div>
                             <div class="form-group">
                                 <label asp-for="City">City <span class="required">*</span></label>
                                 <select asp-for="City" id="City" required>
                                     <option value="">Loading...</option>
                                 </select>
                             </div>
                             <div class="form-group">
                                 <label>Sector / Ward <span class="required">*</span></label>
                                 <select id="Area" name="Area" required>
                                     <option value="">Loading...</option>
                                 </select>
                             </div>
                             <div class="form-group">
                                 <label>PIN Code <span class="required">*</span></label>
                                 <input type="text" id="PinCode" name="PinCode" placeholder="160022" maxlength="6" required>
                             </div>
                         </div>

                    <!-- SECTION 2: Complaint Details -->
                    <div class="form-card">
                        <div class="form-card-title"><span class="badge">2</span> Complaint Information</div>
                        <div class="form-grid-2">
                            <div class="form-group">
                                <label asp-for="ComplaintTitle">Complaint Title <span class="required">*</span></label>
                                <input asp-for="ComplaintTitle" id="ComplaintTitle" placeholder="Brief title of the issue" required>
                            </div>
                            
                            <div class="form-group">
                                <label asp-for="Department">Department Category <span class="required">*</span></label>
                                <select asp-for="Department" id="Department" required>
                                    <option value="">Select Department</option>
                                </select>
                                <div class="form-note">Select the relevant department for quicker resolution</div>
                            </div>

                            <div class="form-group">
                                <label>Source of Complaint <span class="required">*</span></label>
                                <select id="Source" name="Source" required>
                                    <option value="">— Select Source —</option>
                                    <option value="Portal">Web Portal</option>
                                    <option value="Mobile">Mobile App</option>
                                    <option value="WhatsApp">WhatsApp</option>
                                    <option value="Helpline">Helpline Call</option>
                                </select>
                                <div class="form-note">How was this issue reported?</div>
                            </div>

                            <div class="form-group">
                                <label>Date of Incident <span class="required">*</span></label>
                                <input type="date" id="incidentDate" name="IncidentDate" required>
                            </div>

                            <div class="form-group span-2">
                                <label>Complaint Site (Exact Location) <span class="required">*</span></label>
                                <input type="text" id="Site" name="Site" placeholder="e.g. Sector 22-B, near Pole No. 34, Opposite park" required>
                            </div>
                        </div>
                        
                        <div class="form-grid-2" style="margin-top: 20px;">
                            <div class="form-group span-2">
                                <label asp-for="Description">Detailed Description <span class="required">*</span></label>
                                <textarea asp-for="Description" id="Description" rows="5" minlength="200" placeholder="Describe the issue in detail (minimum 200 characters). Include the exact location, the nature of the problem, and any previous action taken..." required></textarea>
                                <div class="form-note d-flex justify-content-between">
                                    <span>Minimum 200 characters required. Avoid special characters (#$@@^*~|!).</span>
                                    <span id="descCount" style="color:red; font-weight:bold;">0 / 200 (Min)</span>
                                </div>
                            </div>
                            <div class="form-group span-2">
                                <label>Upload Evidence (Optional)</label>
                                <div class="upload-area">
                                    <div class="upload-icon">📎</div>
                                    <p>Click to upload or drag & drop files here</p>
                                    <small>Supported formats: JPG, PNG, MP4 (Max 10 MB per file)</small>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="form-actions">
                        <button type="button" class="btn-secondary-custom" onclick="window.history.back()">Cancel</button>
                        <button type="submit" class="btn-primary-custom" id="btnSubmit">Submit Complaint &rarr;</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            
            // 1. Set today's date for the Date of Incident field
            const dateInput = document.getElementById('incidentDate');
            if(dateInput) {
              dateInput.valueAsDate = new Date();
            }

            // 2. Generate and Display the Complaint No immediately on form load
            const year = new Date().getFullYear();
            const randomSeq = Math.floor(10000 + Math.random() * 90000); 
            const compNo = `CHD/ELE/${year}/${randomSeq}`;
            const compDisplay = document.getElementById('generatedComplaintNo');
            if(compDisplay) {
                compDisplay.innerText = compNo;
                $('#ComplaintNo').val(compNo); // Put in hidden field so it gets submitted
            }

            // Load Masters
            // Load States
            $.ajax({
                url: '/api/MasterData/states',
                type: 'GET',
                success: function (data) {
                    var $state = $('#State');
                    $state.empty();
                    $state.append('<option value="">Select State</option>');
                    data.forEach(function (state) {
                        $state.append($('<option></option>').val(state).text(state));
                    });
                }
            });

            // Dependent: Cities by State
            $('#State').on('change', function() {
                var state = $(this).val();
                var $city = $('#City'); $city.empty();
                $city.append('<option value="">Select City</option>');
                $('#Area').empty().append('<option value="">Select Sector/Ward</option>');
                
                if (state) {
                    $.get('/api/MasterData/cities-by-state?state=' + state, function(data) {
                        data.forEach(x => $city.append($('<option>').val(x).text(x)));
                    });
                }
            });

            // Dependent: Sectors by City
            $('#City').on('change', function() {
                var city = $(this).val();
                var $area = $('#Area'); $area.empty();
                $area.append('<option value="">Select Sector/Ward</option>');
                
                if (city) {
                    $.get('/api/MasterData/sectors-by-city?city=' + city, function(data) {
                        data.forEach(x => $area.append($('<option>').val(x).text(x)));
                    });
                }
            });

            // Load Departments
            $.ajax({
                url: '/api/MasterData/departments',
                type: 'GET',
                success: function (data) {
                    var $dept = $('#Department');
                    $dept.empty();
                    $dept.append('<option value="">Select Department</option>');
                    data.forEach(function (dept) {
                        $dept.append($('<option></option>').val(dept.code).text(dept.name));
                    });
                }
            });

            // Description character count
            $('#Description').on('input', function () {
                var len = $(this).val().length;
                $('#descCount').text(len + ' / 200 (Min)');
                if(len < 200) {
                    $('#descCount').css('color', 'red');
                } else {
                    $('#descCount').css('color', 'green');
                }
            });

            // Smart Auto-Selection logic
            $('#ComplaintTitle').on('keyup', function () {
                var title = $(this).val().toLowerCase();
                
                // Define keywords
                var electricalKw = ["wire", "electricity", "spark", "power", "pole", "light"];
                var waterKw = ["water", "leak", "pipe", "plumbing", "drain", "sewage"];
                var sanitationKw = ["garbage", "trash", "clean", "sweep", "waste"];
                var roadKw = ["road", "pothole", "street", "footpath", "highway"];
                
                if (electricalKw.some(kw => title.includes(kw))) {
                    $("#Department").val("ELE");
                } else if (waterKw.some(kw => title.includes(kw))) {
                    $("#Department").val("WAT");
                } else if (sanitationKw.some(kw => title.includes(kw))) {
                    $("#Department").val("SAN");
                } else if (roadKw.some(kw => title.includes(kw))) {
                    $("#Department").val("ROA");
                }
            });

            // AJAX Form Submit
            $('#complaintForm').on('submit', function (e) {
                e.preventDefault();

                var description = $('#Description').val();
                if(description.length < 200) {
                    Swal.fire({
                        icon: 'warning',
                        title: 'Description Too Short',
                        text: 'Description must be at least 200 characters long.',
                        confirmButtonColor: '#2563eb'
                    });
                    return;
                }

                var formData = {
                    ComplaintNo: $('#ComplaintNo').val(), 
                    ComplaintTitle: $('#ComplaintTitle').val(),
                    State: $('#State').val(),
                    City: $('#City').val(),
                    Area: $('#Area').val(),
                    Department: $('#Department').val(),
                    Description: description,
                    Source: $('#Source').val(),
                    Street: $('#Street').val(),
                    Locality: $('#Locality').val(),
                    PinCode: $('#PinCode').val(),
                    IncidentDate: $('#incidentDate').val(),
                    Site: $('#Site').val()
                };

                $.ajax({
                    url: '/Complaint/Submit',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(formData),
                    success: function (response) {
                        if (response.success) {
                            Swal.fire({
                                icon: 'success',
                                title: 'Success!',
                                text: 'Complaint Submitted Successfully! Complaint No: ' + response.complaintNo,
                                confirmButtonColor: '#2563eb'
                            }).then(() => {
                                $('#complaintForm')[0].reset();
                                $('#descCount').text('0 / 200 (Min)').css('color', 'red');
                            });
                        } else {
                            Swal.fire({
                                icon: 'error',
                                title: 'Error',
                                text: response.message,
                                confirmButtonColor: '#2563eb'
                            });
                        }
                    },
                    error: function () {
                        Swal.fire({
                            icon: 'error',
                            title: 'Oops...',
                            text: 'An error occurred while submitting the form.',
                            confirmButtonColor: '#2563eb'
                        });
                    }
                });
            });
        });
    </script>
}
