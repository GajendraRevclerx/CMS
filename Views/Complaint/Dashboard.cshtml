@model IEnumerable<CMS.Models.Complaint>

@{
    ViewData["Title"] = "My Complaints";
}

<h2 class="mt-4 mb-4">My Dashboard</h2>

<a asp-action="Submit" class="btn btn-primary mb-3">Register New Complaint</a>

<div class="card shadow-sm">
    <div class="card-body">
        <table class="table table-bordered table-striped" id="complaintsTable">
            <thead class="table-dark">
                <tr>
                    <th>Complaint No</th>
                    <th>Title</th>
                    <th>Department</th>
                    <th>Date</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach(var item in Model)
                {
                    <tr>
                        <td>@item.ComplaintNo</td>
                        <td>@item.ComplaintTitle</td>
                        <td>@item.Department</td>
                        <td>@item.CreatedDate.ToString("dd MMM yyyy")</td>
                        <td>
                            @if(item.Status == "Pending")
                            {
                                <span class="badge bg-danger">Pending</span>
                            }
                            else if (item.Status == "Assigned" || item.Status == "In Progress")
                            {
                                <span class="badge bg-warning text-dark">@item.Status</span>
                            }
                            else if (item.Status == "Resolved")
                            {
                                <span class="badge bg-success">Resolved</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">@item.Status</span>
                            }
                        </td>
                    </tr>
                }
                @if(!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center">No complaints found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
