  function applyFilters() {
      const search = $('#complaintSearch').val()?.toLowerCase().trim() || "";
      const status = $('#filterStatus').val();
      const selOfficer = $('#filterOfficer').val();
      const priority = $('#filterPriority').val();
      
      const dateVal = $('#filterDateRange').val();
      const drp = $('#filterDateRange').data('daterangepicker');
      const start = (dateVal && drp) ? drp.startDate.startOf('day') : null;
      const end = (dateVal && drp) ? drp.endDate.endOf('day') : null;

      $('.complaint-row').each(function() {
          const row = $(this);
          const rowText = row.text().toLowerCase();
          const rowStatus = row.data('status');
          const rowOfficer = row.data('officer');
          const rowPriority = row.data('priority');
          const rowDateStr = row.data('date');
          const rowDate = moment(rowDateStr, 'YYYY-MM-DD');

          let show = true;

          if (search && !rowText.includes(search)) show = false;
          if (status && rowStatus !== status) show = false;
          
          if (selOfficer && selOfficer !== "" && selOfficer !== "null") {
              if (rowOfficer != selOfficer) show = false;
          }
          
          if (priority && rowPriority !== priority) show = false;
          
          if (start && end && rowDate.isValid()) {
              if (rowDate.isBefore(start) || rowDate.isAfter(end)) show = false;
          }

          if (show) row.show();
          else row.hide();
      });
  }

  function applyRosterFilters() {
      const name = $('#rosterFilterName').val();
      const mobile = $('#rosterSearchMobile').val()?.toLowerCase().trim() || "";
      const dept = $('#rosterFilterDept').val();

      $('.roster-row').each(function() {
          const row = $(this);
          const rowName = row.data('name');
          const rowMobile = row.data('mobile').toString();
          const rowDept = row.data('dept');

          let show = true;
          if (name && rowName !== name) show = false;
          if (mobile && !rowMobile.includes(mobile)) show = false;
          if (dept && rowDept !== dept) show = false;

          if (show) row.show();
          else row.hide();
      });
  }

