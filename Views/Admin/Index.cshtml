  function doTrack() {
      const val = $('#trackInput').val().trim();
      if(!val) return;
      const items = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model));
      const match = items.find(i => i.ComplaintNo === val);
      if(match) {
          $('#trackAck').text(match.ComplaintNo);
          $('#trackTitle').text(match.ComplaintTitle);
          
          let step = 1;
          if (match.Status === "Assigned") step = 2;
          if (match.Status === "Resolved" || match.Status === "Closed") step = 3;
          
          let timelineHtml = `
              <div class="tl-item"><div class="tl-dot-wrap"><div class="tl-dot" style="background:${step >= 1 ? 'var(--green)' : 'var(--border)'}"></div><div class="tl-line"></div></div><div class="tl-content"><div class="tl-title">Registered</div><div class="tl-sub">Case created in registry.</div></div></div>
              <div class="tl-item"><div class="tl-dot-wrap"><div class="tl-dot" style="background:${step >= 2 ? 'var(--green)' : 'var(--border)'}"></div><div class="tl-line"></div></div><div class="tl-content"><div class="tl-title">Assigned</div><div class="tl-sub">Assigned to an officer.</div></div></div>
              <div class="tl-item"><div class="tl-dot-wrap"><div class="tl-dot" style="background:${step >= 3 ? 'var(--green)' : 'var(--border)'}"></div></div><div class="tl-content"><div class="tl-title">Resolved</div></div></div>
          `;
          
          if (match.Status === "Resolved" && match.ResolutionRemark) {
              timelineHtml += `
                  <div style="background:#f0fff4;border-radius:8px;padding:12px;margin-top:15px;border-left:4px solid var(--green);">
                      <div style="font-weight:700;font-size:12px;color:#2f855a;margin-bottom:4px;text-transform:uppercase;">Resolution Remark</div>
                      <div style="font-size:13px;color:#22543d;">${match.ResolutionRemark}</div>
                  </div>
              `;
          }
          
          $('#trackResult .timeline').html(timelineHtml);
          $('#trackResult').show();
      } else {
          Swal.fire('Not Found', 'No complaint found with this number.', 'warning');
      }
  }

