             'Today': [moment(), moment()],
             'Yesterday': [moment().subtract(1, 'days'), moment().subtract(1, 'days')],
             'Last 7 Days': [moment().subtract(6, 'days'), moment()],
             'Last 30 Days': [moment().subtract(29, 'days'), moment()],
             'This Month': [moment().startOf('month'), moment().endOf('month')],
             'Last Month': [moment().subtract(1, 'month').startOf('month'), moment().subtract(1, 'month').endOf('month')]
          }
      });

      $('#filterDateRange').on('apply.daterangepicker', function(ev, picker) {
          console.log("Date Range Applied:", picker.startDate.format('YYYY-MM-DD'));
          $(this).val(picker.startDate.format('DD/MM/YYYY') + ' - ' + picker.endDate.format('DD/MM/YYYY'));
          applyFilters();
      });

      $('#filterDateRange').on('cancel.daterangepicker', function(ev, picker) {
          $(this).val('');
          applyFilters();
      });

      // Initialize Select2 for Dashboard Filters
      $('#filterDept').select2({
          placeholder: "Select Department",
          allowClear: true,
          width: '100%'
      }).on('change', function() {
          aCascadeDiv(this);
      });

      $('#filterDiv').select2({
          placeholder: "Select Division",
          allowClear: true,
          width: '100%'
      }).on('change', function() {
          aCascadeSub(this);
      });

      $('#filterSub').select2({
          placeholder: "Select Sub-Div",
          allowClear: true,
          width: '100%'
      }).on('change', function() {
          aCascadeOff(this);
      });

      $('#filterOff').select2({
          placeholder: "Select Officer",
          allowClear: true,
          width: '100%'
      }).on('change', function() {
          applyFilters();
      });

      // Initialize Select2 for Roster Name Filter
      $('#rosterFilterName').select2({
          placeholder: "Search Officer",
          width: '100%'
      }).on('change', function() {
          applyRosterFilters();
      });

      // Initialize Select2 for Officer Cascading Dropdowns
      $('#offDept, #offDiv, #offSubDiv').select2({
          placeholder: "Select...",
          width: '100%',
          dropdownParent: $('#officerModal')
      });

      // Cascading Listeners for Officer Modal
      $('#offDept').on('change', function() {
          loadDivisionsForOfficer();
      });

      $('#offDiv').on('change', function() {
          loadSubDivisionsForOfficer();
      });

      $('#rosterSearchMobile').on('input', function() {
          applyRosterFilters();
      });

      $('#rosterFilterDept').on('change', function() {
          applyRosterFilters();
      });

      let hash = window.location.hash.replace('#', '');
      if (hash) {
          showPanel(hash);
      }

      // -- Detailed Reports Initializer --
      $('#reportDateRange').daterangepicker({
          opens: 'left',
          autoUpdateInput: false,
          locale: { cancelLabel: 'Clear', format: 'DD/MM/YYYY' },
          ranges: {
             'Today': [moment(), moment()],
             'Yesterday': [moment().subtract(1, 'days'), moment().subtract(1, 'days')],
             'Last 7 Days': [moment().subtract(6, 'days'), moment()],
             'Last 30 Days': [moment().subtract(29, 'days'), moment()],
             'This Month': [moment().startOf('month'), moment().endOf('month')]
          }
      });

      $('#reportDateRange').on('apply.daterangepicker', function(ev, picker) {
          $(this).val(picker.startDate.format('DD/MM/YYYY') + ' - ' + picker.endDate.format('DD/MM/YYYY'));
          renderReportTable();
      });

      $('#reportDateRange').on('cancel.daterangepicker', function(ev, picker) {
          $(this).val('');
          renderReportTable();
      });

      renderReportTable();
  });

  // ========== DASHBOARD (ALL COMPLAINTS) FILTERS ==========
  function aCascadeDiv(el) {
      const deptCode = $(el).val();
      const divSel = $('#filterDiv').html('<option value="">All Divisions</option>');
      const subSel = $('#filterSub').html('<option value="">All Sub-Divs</option>');
      const offSel = $('#filterOff').html('<option value="">All Officers</option>');

      if (deptCode) {
          const dObj = (masters.Departments || []).find(d => String(d.Code).trim().toLowerCase() === String(deptCode).trim().toLowerCase());
          const deptName = dObj ? dObj.Name : '';
          
          // Populate Divisions
          const filteredDivs = (masters.Divisions || []).filter(d => String(d.DepartmentName).trim().toLowerCase() === String(deptName).trim().toLowerCase());
          filteredDivs.forEach(d => divSel.append(`<option value="${d.Name}">${d.Name}</option>`));
          
          // Show all officers for this dept initially
          const matchingOffs = (officers || []).filter(o => String(o.Department).trim().toLowerCase() === String(deptName).trim().toLowerCase());
          matchingOffs.forEach(o => offSel.append(`<option value="${o.Id}">${o.FullName}</option>`));
      }
      applyFilters();
  }

  function aCascadeSub(el) {
      const deptCode = $('#filterDept').val();
      const div = $(el).val();
      const subSel = $('#filterSub').html('<option value="">All Sub-Divs</option>');
      const offSel = $('#filterOff').html('<option value="">All Officers</option>');

      if (div) {
          const dObj = (masters.Departments || []).find(d => String(d.Code).trim().toLowerCase() === String(deptCode).trim().toLowerCase());
          const deptName = dObj ? dObj.Name : '';

          const filteredSubs = (masters.SubDivisions || []).filter(s => 
              String(s.DepartmentName).trim().toLowerCase() === String(deptName).trim().toLowerCase() && 
              String(s.DivisionName).trim().toLowerCase() === String(div).trim().toLowerCase()
          );
          filteredSubs.forEach(s => subSel.append(`<option value="${s.Name}">${s.Name}</option>`));

          const matchingOffs = (officers || []).filter(o => 
              String(o.Department).trim().toLowerCase() === String(deptName).trim().toLowerCase() && 
              String(o.Division).trim().toLowerCase() === String(div).trim().toLowerCase()
          );
          matchingOffs.forEach(o => offSel.append(`<option value="${o.Id}">${o.FullName}</option>`));
      } else {
          aCascadeDiv($('#filterDept')); // Fallback to dept level
      }
      applyFilters();
  }

  function aCascadeOff(el) {
    const deptCode = $('#filterDept').val();
    const div = $('#filterDiv').val();
    const sub = $(el).val();
    const offSel = $('#filterOff').html('<option value="">All Officers</option>');

    if (sub) {
        const dObj = (masters.Departments || []).find(d => String(d.Code).trim().toLowerCase() === String(deptCode).trim().toLowerCase());
        const deptName = dObj ? dObj.Name : '';
        const matchingOffs = (officers || []).filter(o => 
            String(o.Department).trim().toLowerCase() === String(deptName).trim().toLowerCase() && 
            String(o.Division).trim().toLowerCase() === String(div).trim().toLowerCase() && 
            String(o.SubDivision).trim().toLowerCase() === String(sub).trim().toLowerCase()
        );
        matchingOffs.forEach(o => offSel.append(`<option value="${o.Id}">${o.FullName}</option>`));
    } else {
        aCascadeSub($('#filterDiv')); // Fallback to div level
    }
    applyFilters();
  }

  function applyFilters() {
      const search = $('#complaintSearch').val().toLowerCase().trim();
      const status = $('#filterStatus').val();
      const deptCode = $('#filterDept').val();
      const div = $('#filterDiv').val();
      const sub = $('#filterSub').val();
      const off = $('#filterOff').val();
      const priority = $('#filterPriority').val();
      const dateVal = $('#filterDateRange').val();
      
      const drp = $('#filterDateRange').data('daterangepicker');
      const start = (dateVal && drp) ? drp.startDate.startOf('day') : null;
      const end = (dateVal && drp) ? drp.endDate.endOf('day') : null;

      let deptName = "";
      // Removed redundant cleanMatch definition (now global)

      if (deptCode) {
          const dObj = (masters.Departments || []).find(d => cleanMatch(d.Code, deptCode));
          if (dObj) deptName = dObj.Name;
      }

      $('.complaint-row').each(function() {
          const $row = $(this);
          let match = true;
          
          if (search && !$row.text().toLowerCase().includes(search)) match = false;
          if (status && !cleanMatch(status, $row.data('status'))) match = false;
          
          if (deptCode) {
              const rowDept = $row.data('dept');
              const isMatch = cleanMatch(deptCode, rowDept) || cleanMatch(deptName, rowDept);
              if (!isMatch) match = false;
          }

          if (div || sub) {
              const offId = $row.data('off');
              const officer = (officers || []).find(o => o.Id === offId || o.MobileNo === offId);
              
              const rowDiv = $row.data('div');
              const rowSub = $row.data('sub');
              
              if (div) {
                  const matchDiv = cleanMatch(div, rowDiv) || (officer && cleanMatch(div, officer.Division));
                  if (!matchDiv) match = false;
              }
              if (sub) {
                  const matchSub = cleanMatch(sub, rowSub) || (officer && cleanMatch(sub, officer.SubDivision));
                  if (!matchSub) match = false;
              }
          }

          if (off && !cleanMatch(off, $row.data('off'))) match = false;
          if (priority && !cleanMatch(priority, $row.data('priority'))) match = false;
          
          if (start && end) {
              const cDate = moment($row.data('date'));
              if (cDate.isBefore(start) || cDate.isAfter(end)) match = false;
          }

          $row.toggle(match);
      });
  }

  function resetAFilters() {
      $('#filterDept, #filterDiv, #filterSub, #filterOff').val('').trigger('change.select2');
      $('#complaintSearch, #filterStatus, #filterPriority, #filterDateRange').val('');
      applyFilters();
  }

  // ========== REPORTS LOGIC (FLAT LIST) ==========
  const allUsers = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.Users));
  const userMap = {};
  const userMobileMap = {};
  allUsers.forEach(u => { 
      userMap[u.MobileNo] = u.FullName;
      userMobileMap[u.Id] = u.MobileNo; 
  });

  const allComplaintsData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model));

  function cascadeRepDiv(el) {
    const deptCode = $(el).val();
    const deptName = (masters.Departments.find(d => d.Code === deptCode) || {}).Name;
    const divSel = $('#repDiv').html('<option value="">All Divisions</option>');
    $('#repSub').html('<option value="">All Sub-Divs</option>');
    $('#repOff').html('<option value="">All Officers</option>');

    if (deptName) {
        const filtered = (masters.Divisions || []).filter(d => d.DepartmentName === deptName);
        filtered.forEach(d => divSel.append(`<option value="${d.Name}">${d.Name}</option>`));
        
        // Also populate officers for this dept name
        const matchingOffs = (officers || []).filter(o => o.Department === deptName);
        matchingOffs.forEach(o => $('#repOff').append(`<option value="${o.Id}">${o.FullName}</option>`));
    }
    renderReportTable();
  }

  function cascadeRepSub(el) {
    const deptCode = $('#repDept').val();
    const deptName = (masters.Departments.find(d => d.Code === deptCode) || {}).Name;
    const div = $(el).val();
    const subSel = $('#repSub').html('<option value="">All Sub-Divs</option>');
    $('#repOff').html('<option value="">All Officers</option>');

    if (div) {
        const filtered = (masters.SubDivisions || []).filter(s => s.DepartmentName === deptName && s.DivisionName === div);
        filtered.forEach(s => subSel.append(`<option value="${s.Name}">${s.Name}</option>`));

        const matchingOffs = (officers || []).filter(o => o.Department === deptName && o.Division === div);
        matchingOffs.forEach(o => $('#repOff').append(`<option value="${o.Id}">${o.FullName}</option>`));
    }
    renderReportTable();
  }

  function cascadeRepOff(el) {
    const deptCode = $('#repDept').val();
    const div = $('#repDiv').val();
    const sub = $(el).val();
    const offSel = $('#repOff').html('<option value="">All Officers</option>');

    if (sub) {
        const deptName = (masters.Departments.find(d => d.Code === deptCode) || {}).Name;
        const matchingOffs = (officers || []).filter(o => o.Department === deptName && o.Division === div && o.SubDivision === sub);
        matchingOffs.forEach(o => offSel.append(`<option value="${o.Id}">${o.FullName}</option>`));
    }
    renderReportTable();
  }

  function renderReportTable() {
      const dateVal = $('#reportDateRange').val();
      const drp = $('#reportDateRange').data('daterangepicker');
      const start = (dateVal && drp) ? drp.startDate.startOf('day') : null;
      const end = (dateVal && drp) ? drp.endDate.endOf('day') : null;
      const statusFilter = $('#reportStatus').val();
      
      const selDept = $('#repDept').val();
      const selDiv = $('#repDiv').val();
      const selSub = $('#repSub').val();
      const selOff = $('#repOff').val();

      // 1. Filter raw data
      let filtered = (allComplaintsData || []).filter(c => {
          let match = true;
          const cDate = moment(c.CreatedDate);
          if (start && end && (cDate.isBefore(start) || cDate.isAfter(end))) match = false;
          if (statusFilter && c.Status !== statusFilter) match = false;
          
          if (selDept && c.Department !== selDept) match = false;
          
          // Cascading filter logic for Division/Sub-Division via Assigned Officer
          if (selDiv || selSub) {
              const officer = (officers || []).find(o => o.Id === c.AssignedToId || o.MobileNo === c.AssignedToId);
              if (selDiv && (!officer || officer.Division !== selDiv)) match = false;
              if (selSub && (!officer || officer.SubDivision !== selSub)) match = false;
          }

          if (selOff) {
              const offMobile = userMobileMap[selOff];
              if (c.AssignedToId !== selOff && c.RegisteredById !== offMobile) match = false;
          }
          
          return match;
      });

      const head = $('#reportTableHead');
      const body = $('#reportTableBody');
      head.empty();
      body.empty();

      if (filtered.length === 0) {
          $('#reportEmptyState').show();
          $('#reportTable').hide();
          return;
      }
      $('#reportEmptyState').hide();
      $('#reportTable').show();

      head.append(`<tr>
          <th>#</th>
          <th>Ack No</th>
          <th>Citizen</th>
          <th>Mobile</th>
          <th>Title / Issue</th>
          <th>Department</th>
          <th>Registered By</th>
          <th>Status</th>
          <th>Assigned To</th>
          <th>Date</th>
      </tr>`);

      filtered.forEach((c, idx) => {
          const regBy = userMap[c.RegisteredById] || c.RegisteredById || "Self";
          body.append(`<tr>
              <td style="font-size:11px;color:#94a3b8;">${idx + 1}</td>
              <td style="font-weight:700;">${c.ComplaintNo}</td>
              <td>${c.FullName || 'N/A'}</td>
              <td style="font-size:11px;">${c.UserId}</td>
              <td>${c.ComplaintTitle}</td>
              <td><span class="pill pill-blue">${c.Department}</span></td>
              <td><div style="font-size:12px;font-weight:600;">${regBy}</div></td>
              <td><span class="pill pill-${c.Status === 'Resolved' ? 'green' : (c.Status === 'Assigned' ? 'blue' : 'amber')}">${c.Status}</span></td>
              <td><div style="font-size:11px;">${c.AssignedToName || 'Not Assigned'}</div></td>
              <td style="font-size:11px;">${moment(c.CreatedDate).format('DD MMM YY')}</td>
          </tr>`);
      });

      filterReportTable(); // re-apply search if any
  }

  function filterReportTable() {
      const search = $('#reportSearch').val().toLowerCase().trim();
      let visible = 0;
      $('#reportTableBody tr').each(function() {
          const text = $(this).text().toLowerCase();
          const show = !search || text.includes(search);
          $(this).toggle(show);
          if (show) visible++;
      });
      if (visible === 0) $('#reportEmptyState').show();
      else $('#reportEmptyState').hide();
  }

  function resetReportFilters() {
      $('#repDept, #repDiv, #repSub, #repOff').val('');
      $('#repDiv, #repSub, #repOff').html('<option value="">All ...</option>'); // reset content
      $('#reportDateRange').val('');
      $('#reportSearch').val('');
      $('#reportStatus').val('');
      renderReportTable();
  }

  function downloadReportPDF() {
      const element = document.getElementById('reportExportArea');
      const dateStr = $('#reportDateRange').val() || 'All Time';
      const deptStr = $('#repDept').val() || 'All Departments';
      
      // Update print meta
      $('#printReportMeta').text(`Detailed Complaint Report | Dept: ${deptStr} | Range: ${dateStr} | Generated: ${moment().format('DD MMM YYYY, HH:mm')}`);
      $('.print-only-header').show();
      
      const opt = {
          margin: 10,
          filename: `CCMS_Detailed_Report_${moment().format('YYYYMMDD')}.pdf`,
          image: { type: 'jpeg', quality: 0.98 },
          html2canvas: { scale: 2, useCORS: true },
          jsPDF: { unit: 'mm', format: 'a4', orientation: 'landscape' }
      };

      html2pdf().set(opt).from(element).save().then(() => {
          $('.print-only-header').hide();
      });
  }
</script>

<div id="fullTrackModal" class="modal-overlay">
  <div class="modal" style="max-width:800px;">
    <div class="modal-hdr">
        <h3>📄 Detailed Complaint Overview</h3>
        <button class="modal-close" onclick="closeModal('fullTrackModal')">&times;</button>
    </div>
    <div class="modal-body">
        <div id="fullTrackContent" style="padding:10px; background:#fff;"></div>
        <span id="trackAckGlobal" style="display:none;"></span>
    </div>
    <div class="modal-footer">
        <button class="btn btn-outline" onclick="closeModal('fullTrackModal')">Close</button>
        <button class="btn btn-primary" onclick="downloadComplaintPDF()">Download as PDF</button>
    </div>
  </div>
</div>

</body>
</html>
