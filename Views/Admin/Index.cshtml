              if (res.status === "Resolved" || res.status === "Closed") step = 3;
              
              let timelineHtml = `
                  <!-- Section 1: Registered -->
                  <div class="tl-item">
                      <div class="tl-dot-wrap"><div class="tl-dot" style="background:var(--green)"></div><div class="tl-line"></div></div>
