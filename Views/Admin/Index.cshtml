<script src="/lib/jquery/dist/jquery.min.js"></script>
<script src="/lib/sweetalert2/sweetalert2.all.min.js"></script>
<script src="/lib/select2/js/select2.min.js"></script>
<script src="/lib/moment/moment.min.js"></script>
<script src="/lib/daterangepicker/daterangepicker.min.js"></script>
<script src="/lib/html2pdf/html2pdf.bundle.min.js"></script>
<script src="/lib/chart.js/chart.min.js"></script>
<script>
  const masters = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(masters));
  const officers = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(allOfficers));

  // Global helper for case-insensitive and trimmed string matching
  const cleanMatch = (val, attr) => {
      if (!val) return true;
      if (!attr) return false;
      return String(val).trim().toLowerCase() === String(attr).trim().toLowerCase();
  };

  function cascadeDiv(el) {
      const row = $(el).closest('.assign-flow');
      const dept = $(el).val();
      const divSel = row.find('.assign-div').html('<option value="">Select Division</option>');
      const subSel = row.find('.assign-sub').html('<option value="">Select Sub-Div</option>');
      const desigSel = row.find('.assign-desig').html('<option value="">Select Designation</option>');
      const offSel = row.find('.assign-off').html('<option value="">Select Officer</option>');

      if (!dept) return;

      // 1. Check for Divisions
      const filtered = (masters.Divisions || []).filter(d => cleanMatch(d.DepartmentName, dept));
      if (filtered.length > 0) {
          filtered.forEach(d => divSel.append(`<option value="${d.Name}">${d.Name}</option>`));
      } else {
          // If no Divisions, show officers for this Department directly
          const matches = officers.filter(o => cleanMatch(o.Department, dept));
          if (matches.length > 0) {
              matches.forEach(o => offSel.append(`<option value="${o.Id}" data-name="${o.FullName}">${o.FullName}</option>`));
          }
      }
  }

  function cascadeSub(el) {
      const row = $(el).closest('.assign-flow');
      const dept = row.find('.assign-dept').val();
      const div = $(el).val();
      const subSel = row.find('.assign-sub').html('<option value="">Select Sub-Div</option>');
      const desigSel = row.find('.assign-desig').html('<option value="">Select Designation</option>');
      const offSel = row.find('.assign-off').html('<option value="">Select Officer</option>');

      if (!div) return;

      // 1. Check for Sub-Divisions
      const filteredSubs = (masters.SubDivisions || []).filter(s => cleanMatch(s.DepartmentName, dept) && cleanMatch(s.DivisionName, div));
      if (filteredSubs.length > 0) {
          filteredSubs.forEach(s => subSel.append(`<option value="${s.Name}">${s.Name}</option>`));
      } else {
          // If no Sub-Divisions, show officers for this Division directly
          const matches = officers.filter(o => cleanMatch(o.Department, dept) && cleanMatch(o.Division, div));
          if (matches.length > 0) {
              matches.forEach(o => offSel.append(`<option value="${o.Id}" data-name="${o.FullName}">${o.FullName}</option>`));
          }
      }
  }

  function cascadeDesig(el) {
      const row = $(el).closest('.assign-flow');
      const dept = row.find('.assign-dept').val();
      const div = row.find('.assign-div').val();
      const sub = $(el).val();
      const desigSel = row.find('.assign-desig').html('<option value="">Select Designation</option>');
      const offSel = row.find('.assign-off').html('<option value="">Select Officer</option>');

      if (!sub) return;

      // 1. Check for Designations
      const matchingOfficers = officers.filter(o => cleanMatch(o.Department, dept) && cleanMatch(o.Division, div) && cleanMatch(o.SubDivision, sub));
      const uniqueDesigs = [...new Set(matchingOfficers.filter(o => o.Designation).map(o => o.Designation))];

      if (uniqueDesigs.length > 0) {
          uniqueDesigs.forEach(d => desigSel.append(`<option value="${d}">${d}</option>`));
      } else {
          // If no Designations, show officers for this Sub-Division directly
          if (matchingOfficers.length > 0) {
              matchingOfficers.forEach(o => offSel.append(`<option value="${o.Id}" data-name="${o.FullName}">${o.FullName}</option>`));
          }
      }
  }

  function cascadeOff(el) {
      const row = $(el).closest('.assign-flow');
      const dept = row.find('.assign-dept').val();
      const div = row.find('.assign-div').val();
      const sub = row.find('.assign-sub').val();
      const desig = $(el).val();
      const offSel = row.find('.assign-off').html('<option value="">Select Officer</option>');

      if (!desig) return;

      const filtered = officers.filter(o => cleanMatch(o.Department, dept) && cleanMatch(o.Division, div) && cleanMatch(o.SubDivision, sub) && (cleanMatch(o.Designation, desig) || (!o.Designation && desig === "Officer")));
      if (filtered.length > 0) {
          filtered.forEach(o => offSel.append(`<option value="${o.Id}" data-name="${o.FullName}">${o.FullName}</option>`));
      } else {
          offSel.append('<option value="">No officers found</option>');
      }
  }
  function showPanel(name) {
    document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
    document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
    
    const panel = document.getElementById('panel-' + name);
    if(panel) {
        panel.classList.add('active');
    } else {
        document.getElementById('panel-overview').classList.add('active');
        name = 'overview';
    }
    const nav = document.getElementById('nav-' + name);
    if(nav) nav.classList.add('active');
    document.querySelector('.main-content').scrollTop = 0;

    // Auto-Reset logic for specific panels to ensure consistency
    if (name === 'complaints') {
        resetAFilters();
    } else if (name === 'reports') {
        if (typeof resetReportFilters === 'function') resetReportFilters();
    } else if (name === 'officers') {
        resetRosterFilters();
    } else if (name === 'track') {
        $('#trackInput').val('');
        $('#trackResult').hide();
    } else if (name === 'divisions') {
        $('#gridDivFilterDept, #gridDivSearch').val('');
        applyGridDivFilters();
    } else if (name === 'subdivisions') {
        $('#gridSubFilterDept, #gridSubFilterDiv, #gridSubSearch').val('');
        applyGridSubFilters();
    }
    
    // Update hash for persistence
    if(window.location.hash !== '#' + name) {
        window.history.replaceState(null, null, '#' + name);
    }
  }

  function viewFullDetails(no) {
      if(!no) return;
      $.get('/Complaint/Track', { id: no }).done(function(res) {
          if(res.success) showFullTrackModal(res);
          else Swal.fire('Error', res.message || 'Details not found', 'error');
      });
  }

  function showFullTrackModal(res) {
      if(!res) return;
      let html = `
          <div style="display:grid; grid-template-columns:1fr 1fr; gap:20px; font-size:13px;">
              <div class="detail-section">
                  <h4 style="margin:0 0 10px 0; color:var(--blue); border-bottom:1px solid #eee; padding-bottom:5px; font-size:14px;">Personal Details</h4>
                  <div style="margin-bottom:5px;"><strong>Full Name:</strong> ${res.fullName}</div>
                  <div style="margin-bottom:5px;"><strong>Complainant Mobile:</strong> ${res.userId || '—'}</div>
                  <div style="margin-bottom:5px;"><strong>Email:</strong> ${res.email}</div>
              </div>
              <div class="detail-section">
                  <h4 style="margin:0 0 10px 0; color:var(--blue); border-bottom:1px solid #eee; padding-bottom:5px; font-size:14px;">Address Details</h4>
                  <div style="margin-bottom:5px;"><strong>Street/House:</strong> ${res.street}</div>
                  <div style="margin-bottom:5px;"><strong>Locality:</strong> ${res.locality}</div>
                  <div style="margin-bottom:5px;"><strong>Sector/Area:</strong> ${res.area}</div>
                  <div style="margin-bottom:5px;"><strong>PIN Code:</strong> ${res.pinCode}</div>
              </div>
              <div class="detail-section" style="grid-column: span 2;">
                  <h4 style="margin:10px 0 10px 0; color:var(--blue); border-bottom:1px solid #eee; padding-bottom:5px; font-size:14px;">Complaint Details</h4>
                  <div style="display:grid; grid-template-columns:1fr 1fr; gap:10px;">
                      <div><strong>Ack No:</strong> ${res.complaintNo}</div>
                      <div><strong>Department:</strong> ${res.department}</div>
                      <div><strong>Source:</strong> ${res.source}</div>
                      <div><strong>Incident Date:</strong> ${res.incidentDate}</div>
                      <div><strong>Priority:</strong> <span class="pill ${res.priority === 'High' ? 'pill-red' : (res.priority === 'Medium' ? 'pill-amber' : 'pill-green')}" style="padding:2px 8px; font-size:11px;">${res.priority}</span></div>
                      <div><strong>Exact Site:</strong> ${res.site}</div>
                  </div>
                  <div style="margin-top:10px;"><strong>Title:</strong> ${res.title}</div>
                  <div style="margin-top:8px; background:#f8fafc; padding:12px; border-radius:10px; border:1px solid #eef2ff; color:#334155;">
                      <strong>Description:</strong><br/>
                      <p style="margin-top:5px; line-height:1.6;">${res.description}</p>
                  </div>
              </div>
              <div class="detail-section" style="grid-column: span 2;">
                  <h4 style="margin:10px 0 10px 0; color:var(--blue); border-bottom:1px solid #eee; padding-bottom:5px; font-size:14px;">Status & Resolution</h4>
                  <div style="display:grid; grid-template-columns:1fr 1fr; gap:10px;">
                      <div><strong>Current Status:</strong> <span class="pill pill-blue" style="padding:2px 8px; font-size:11px;">${res.status}</span></div>
                      <div><strong>Assigned To:</strong> ${res.assignedTo} (${res.assignedToMobile})</div>
                      <div><strong>Created Date:</strong> ${res.createdDate}</div>
                      <div><strong>Resolution Date:</strong> ${res.resolutionDate}</div>
                      <div><strong>SLA Time Taken:</strong> ${res.timeTaken}</div>
                  </div>
                  <div style="margin-top:10px; padding:10px; border:1px dashed #cbd5e1; border-radius:8px;">
                      <strong>Resolution Remark:</strong><br/>
                      <span style="color:#166534;">${res.resolutionRemark}</span>
                  </div>
              </div>
          </div>
      `;
      $('#fullTrackContent').html(html);
      $('#trackAckGlobal').text(res.complaintNo); // for PDF naming
      document.getElementById('fullTrackModal').classList.add('show');
  }

  function downloadComplaintPDF() {
      const element = document.getElementById('fullTrackContent');
      const ackNo = $('#trackAckGlobal').text() || 'Complaint_Details';
      
      const opt = {
          margin: 10,
          filename: `Complaint_${ackNo}.pdf`,
          image: { type: 'jpeg', quality: 0.98 },
          html2canvas: { scale: 2, useCORS: true },
          jsPDF: { unit: 'mm', format: 'a4', orientation: 'portrait' }
      };

      html2pdf().set(opt).from(element).save();
  }

  function openTicketModal(id, ack, title, dept, status, officer, priority) {
    $('#modId').val(id);
    $('#modAck').text(ack);
    $('#modTitle').text(title);
    $('#modDept').text(dept);
    $('#modStatus').text(status);
    $('#modStatusSelect').val(status);
    $('#modPrioritySelect').val(priority || 'Medium');
    $('#modPriorityLbl').text(priority || 'Medium');
    $('#modRemark').val('');
    toggleRemarkField();
    document.getElementById('ticketModal').classList.add('show');
  }

  function toggleRemarkField() {
      if ($('#modStatusSelect').val() === 'Resolved') {
          $('#modRemarkGroup').fadeIn();
      } else {
          $('#modRemarkGroup').hide();
      }
  }

  function closeModal(id) { document.getElementById(id).classList.remove('show'); }

  function saveComplaintUpdate() {
      const id = $('#modId').val();
      const status = $('#modStatusSelect').val();
      const priority = $('#modPrioritySelect').val();
      const remark = $('#modRemark').val();

      $.post('/Admin/UpdateStatus', { complaintId: id, status: status, remark: remark })
      .done(function() {
          // Now update priority
          $.post('/Admin/UpdatePriority', { complaintId: id, priority: priority })
          .done(function() {
              Swal.fire('Updated', 'Complaint details have been updated.', 'success').then(() => location.reload());
          });
      })
      .fail(function() {
          Swal.fire('Error', 'Failed to update complaint.', 'error');
      });
  }

  // ========== ADMIN CASCADING FILTERS (COMPLAINTS) ==========
  // Old redundant functions removed. New versions are located at the end of the script.


  // ========== ROSTER & GRID FILTERS (HIERARCHICAL) ==========
  function rCascadeDiv(el) {
    const deptName = $(el).val();
    const divSel = $('#rosterFilterDiv').html('<option value="">All Divisions</option>');
    $('#rosterFilterSub').html('<option value="">All Sub-Divs</option>');

    if (deptName) {
        const filtered = (masters.Divisions || []).filter(d => cleanMatch(d.DepartmentName, deptName));
        if (filtered.length > 0) {
            filtered.forEach(d => divSel.append(`<option value="${d.Name}">${d.Name}</option>`));
        }
    }
    applyRosterFilters();
  }

  function rCascadeSub(el) {
    const deptName = $('#rosterFilterDept').val();
    const divName = $(el).val();
    const subSel = $('#rosterFilterSub').html('<option value="">All Sub-Divs</option>');

    if (divName) {
        const filtered = (masters.SubDivisions || []).filter(s => cleanMatch(s.DepartmentName, deptName) && cleanMatch(s.DivisionName, divName));
        if (filtered.length > 0) {
            filtered.forEach(s => subSel.append(`<option value="${s.Name}">${s.Name}</option>`));
        }
    }
    applyRosterFilters();
  }

  function applyRosterFilters() {
      const dept = $('#rosterFilterDept').val();
      const div = $('#rosterFilterDiv').val();
      const sub = $('#rosterFilterSub').val();
      const search = $('#rosterSearchMobile').val().toLowerCase().trim();

      $('.roster-row').each(function() {
          const $row = $(this);
          let match = true;
          if (dept && !cleanMatch(dept, $row.data('dept'))) match = false;
          if (div && !cleanMatch(div, $row.data('div'))) match = false;
          if (sub && !cleanMatch(sub, $row.data('sub'))) match = false;
          if (search && !$row.text().toLowerCase().includes(search)) match = false;
          $row.toggle(match);
      });
  }

  function resetRosterFilters() {
      $('#rosterFilterDept, #rosterFilterDiv, #rosterFilterSub, #rosterSearchMobile').val('');
      //$('#rosterFilterDiv, #rosterFilterSub').hide();
      applyRosterFilters();
  }

  // ========== GRID MASTER FILTERS (DIV/SUBDIV) ==========
  function applyGridDivFilters() {
      const dept = $('#gridDivFilterDept').val();
      const search = $('#gridDivSearch').val().toLowerCase().trim();
      $('.grid-div-row').each(function() {
          const $row = $(this);
          let match = true;
          if (dept && !cleanMatch(dept, $row.data('dept'))) match = false;
          if (search && !$row.text().toLowerCase().includes(search)) match = false;
          $row.toggle(match);
      });
  }

  function gridSubCascadeDiv(el) {
      const deptName = $(el).val();
      const divSel = $('#gridSubFilterDiv').html('<option value="">All Divisions</option>');
      if (deptName) {
          const filtered = (masters.Divisions || []).filter(d => cleanMatch(d.DepartmentName, deptName));
          if (filtered.length > 0) {
              filtered.forEach(d => divSel.append(`<option value="${d.Name}">${d.Name}</option>`));
          }
      }
      applyGridSubFilters();
  }

  function applyGridSubFilters() {
      const dept = $('#gridSubFilterDept').val();
      const div = $('#gridSubFilterDiv').val();
      const search = $('#gridSubSearch').val().toLowerCase().trim();
      $('.grid-sub-row').each(function() {
          const $row = $(this);
          let match = true;
          if (dept && !cleanMatch(dept, $row.data('dept'))) match = false;
          if (div && !cleanMatch(div, $row.data('div'))) match = false;
          if (search && !$row.text().toLowerCase().includes(search)) match = false;
          $row.toggle(match);
      });
  }

