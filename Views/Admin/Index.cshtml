  function exportCSV() {
      let csv = [];
      const rows = document.querySelectorAll('#panel-complaints .data-table tr');
      for (let i = 0; i < rows.length; i++) {
          // Skip hidden rows to respect filters
          if (rows[i].offsetParent === null) continue;
          
          let row = [], cols = rows[i].querySelectorAll('td, th');
          for (let j = 0; j < cols.length - 1; j++) {
              // Trim content and escape quotes
              let val = cols[j].innerText.trim().replace(/"/g, '""');
              row.push('"' + val + '"');
          }
          csv.push(row.join(','));
      }
      // Excel needs BOM for UTF-8 and real \n for newlines
      const BOM = '\uFEFF';
      const blob = new Blob([BOM + csv.join('\n')], { type: 'text/csv;charset=utf-8;' });
      const url = window.URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.style.display = 'none';
      a.href = url;
      a.download = 'complaints_export_' + new Date().toISOString().slice(0, 10) + '.csv';
      document.body.appendChild(a);
      a.click();
      window.URL.revokeObjectURL(url);
      document.body.removeChild(a);
  }


