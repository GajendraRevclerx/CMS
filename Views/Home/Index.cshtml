@{
    ViewData["Title"] = "Home Page";
}

<style>
    :root {
        --primary-gradient: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
        --accent-gradient: linear-gradient(135deg, #f97316 0%, #ea580c 100%);
        --glass-bg: rgba(255, 255, 255, 0.9);
        --glass-border: rgba(255, 255, 255, 0.2);
        --text-dark: #1e293b;
        --text-light: #64748b;
    }

    body {
        background: #f1f5f9;
        overflow-x: hidden;
    }

    .hero-section {
        background: var(--primary-gradient);
        min-height: 85vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 30px 10px;
        position: relative;
        color: white;
        clip-path: ellipse(150% 100% at 50% 0%);
    }

    .hero-content {
        text-align: center;
        max-width: 850px;
        z-index: 2;
        animation: fadeIn 1s ease-out;
    }

    .hero-content h1 {
        font-size: 3.5rem;
        font-weight: 800;
        margin-bottom: 20px;
        letter-spacing: -1px;
    }

    .hero-content p {
        font-size: 1.25rem;
        opacity: 0.9;
        margin-bottom: 40px;
    }

    .feature-cards {
        display: flex;
        gap: 30px;
        justify-content: center;
        flex-wrap: wrap;
        margin-top: 20px;
    }

    .card-item {
        background: var(--glass-bg);
        border: 1px solid var(--glass-border);
        backdrop-filter: blur(10px);
        width: 320px;
        padding: 40px 30px;
        border-radius: 24px;
        text-align: center;
        color: var(--text-dark);
        box-shadow: 0 20px 40px rgba(0,0,0,0.1);
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        cursor: pointer;
        position: relative;
        overflow: hidden;
    }

    .card-item:hover {
        transform: translateY(-15px);
        box-shadow: 0 30px 60px rgba(0,0,0,0.15);
    }

    .card-item .icon {
        font-size: 48px;
        margin-bottom: 20px;
        display: block;
        transition: transform 0.3s ease;
    }

    .card-item:hover .icon {
        transform: scale(1.2);
    }

    .card-item h3 {
        font-weight: 700;
        margin-bottom: 15px;
    }

    .card-item p {
        color: var(--text-light);
        font-size: 0.95rem;
        margin-bottom: 0;
    }

    .card-btn {
        margin-top: 25px;
        display: inline-block;
        padding: 10px 25px;
        border-radius: 50px;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.3s ease;
    }

    .btn-track {
        background: var(--primary-gradient);
        color: white !important;
    }

    .btn-register {
        background: var(--accent-gradient);
        color: white !important;
    }

    /* Modal Styling */
    .modal-content {
        border-radius: 20px;
        border: none;
        overflow: hidden;
        box-shadow: 0 25px 50px rgba(0,0,0,0.2);
    }

    .modal-header {
        background: var(--primary-gradient);
        color: white;
        border: none;
        padding: 25px;
    }

    .modal-body {
        padding: 40px;
    }

    .form-control-custom {
        border-radius: 12px;
        padding: 12px 20px;
        background: #f8fafc;
        border: 2px solid transparent;
        transition: all 0.3s ease;
    }

    .form-control-custom:focus {
        background: white;
        border-color: #2a5298;
        box-shadow: 0 0 0 4px rgba(42, 82, 152, 0.1);
        outline: none;
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
    }

    @@media (max-width: 768px) {
        .hero-content h1 { font-size: 2.5rem; }
        .feature-cards { flex-direction: column; align-items: center; }
        .card-item { width: 100%; max-width: 350px; }
    }

    /* Horizontal Tracker Styles */
    .track-step-container {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 40px 10px;
        position: relative;
        overflow: hidden;
    }
    
    .track-step-container::before {
        content: '';
        position: absolute;
        top: 58px;
        left: 50px;
        right: 50px;
        height: 3px;
        background: #e2e8f0;
        z-index: 1;
    }
    
    .track-step-item {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 12px;
        z-index: 2;
        position: relative;
    }
    
    .track-step-circle {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: white;
        border: 3px solid #e2e8f0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 14px;
        color: #94a3b8;
        transition: all 0.4s ease;
        box-shadow: 0 0 0 5px white;
    }
    
    .track-step-item.active .track-step-circle {
        border-color: #3b82f6;
        color: #3b82f6;
        background: white;
        transform: scale(1.1);
        box-shadow: 0 0 20px rgba(59, 130, 246, 0.2), 0 0 0 5px white;
    }
    
    .track-step-item.completed .track-step-circle {
        background: #10b981;
        border-color: #10b981;
        color: white;
    }
    
    .track-step-label {
        font-size: 0.7rem;
        font-weight: 700;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        text-align: center;
    }
    
    .track-step-item.active .track-step-label {
        color: #1e293b;
    }
    
    .track-progress-line {
        position: absolute;
        top: 58px;
        left: 50px;
        height: 3px;
        background: #10b981;
        z-index: 1;
        transition: width 0.8s cubic-bezier(0.4, 0, 0.2, 1);
    }
</style>

<div class="hero-section">
    <div class="hero-content">
        <h3>Empowering Citizens, Enhancing Governance</h3>
        <p>A seamless platform to voice your concerns and track resolutions in real-time. Join thousands of citizens in making our city better.</p>

        <div class="feature-cards">
            <!-- Box 1: Track -->
            <div class="card-item" style="width:50%!important" onclick="$('#trackModal').modal('show')">
                <span class="icon">🔍</span>
                <h3>Track Your Complaint</h3>
                <p>Check the real-time status using your complaint number.</p>
                <div class="card-btn btn-track">Track Complaint</div>
            </div>

            <!-- Box 2: Register -->
@*             <a href="/Complaint/DirectSubmit" class="card-item" style="text-decoration: none;">
                <span class="icon">📝</span>
                <h3>Register a Complaint</h3>
                <p>Submit a new request instantly without a complex login process.</p>
                <div class="card-btn btn-register">File Instant Complaint</div>
            </a> *@
        </div>
    </div>
</div>

<!-- Login Modal -->
<div class="modal fade" id="loginModal" tabindex="-1" aria-labelledby="loginModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="loginModalLabel">Welcome Back</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div id="loginAlert"></div>
                <form id="ajaxLoginForm" method="post">
                    <div class="mb-4">
                        <label class="form-label fw-bold">User ID</label>
                        <input type="text" name="MobileNo" class="form-control form-control-custom" placeholder="Enter your User Id" required>
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-bold">Password</label>
                        <input type="password" name="Password" class="form-control form-control-custom" placeholder="Enter your password" required>
                    </div>
                    <div class="d-grid gap-2 mt-4">
                        <button type="submit" class="btn btn-primary rounded-pill py-3 fw-bold" style="background: var(--primary-gradient); border: none;">Login & Track</button>
                    </div>
                    <div style="display:none;" class="text-center mt-4">
                        <p class="text-muted small">Don't have an account? <a href="/Account/Register" class="text-primary fw-bold">Register Now</a></p>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Track Complaint Modal -->
<div class="modal fade" id="trackModal" tabindex="-1" aria-labelledby="trackModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header" style="background: var(--primary-gradient); color: white; border: none;">
                <h5 class="modal-title" id="trackModalLabel">Track Complaint</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div id="trackContentArea">
                    <div id="trackResult"></div>
                    <form id="trackForm">
                        <div class="mb-4">
                            <label class="form-label fw-bold">Complaint/Acknowledgement No.</label>
                            <input type="text" id="trackId" class="form-control form-control-custom" placeholder="e.g. 2026/0001" required autocomplete="off">
                        </div>
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary rounded-pill py-3 fw-bold" style="background: var(--primary-gradient); border: none;">Search Status</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('#ajaxLoginForm').on('submit', function(e) {
                e.preventDefault();
                var formData = $(this).serialize();
                
                $.ajax({
                    url: '/Account/Login',
                    type: 'POST',
                    data: formData,
                    headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    success: function(response) {
                        if(response.success) {
                            window.location.href = response.redirectUrl;
                        }
                    },
                    error: function(xhr) {
                        var msg = xhr.responseJSON ? xhr.responseJSON.message : "An error occurred. Please try again.";
                        $('#loginAlert').html('<div class="alert alert-danger p-2 small">' + msg + '</div>');
                    }
                });
            });
            
            // Public Tracking
            $('#trackForm').on('submit', function(e) {
                e.preventDefault();
                var id = $('#trackId').val().trim();
                var $result = $('#trackResult');
                
                $result.html('<div class="text-center py-4"><div class="spinner-border text-primary" role="status"></div></div>');
                
                $.ajax({
                    url: '/Complaint/Track',
                    type: 'GET',
                    data: { id: id },
                    success: function(res) {
                        if(res.success) {
                            let step = 1;
                            if (res.status === 'Assigned') step = 2;
                            if (res.status === 'Resolved' || res.status === 'Closed') step = 3;
                            
                            var progressWidth = ((step - 1) / 2) * 100;
                            if (step === 1) progressWidth = 0;

                            $result.html(`
                                <div class="mb-4">
                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                        <h6 class="fw-bold mb-0">${res.complaintNo}</h6>
                                        <span class="badge ${step === 3 ? 'bg-success' : 'bg-primary'} rounded-pill">${res.status}</span>
                                    </div>
                                    <p class="text-muted small">${res.title} · Filed on ${res.createdDate}</p>
                                    
                                    <div class="position-relative">
                                        <div class="track-step-container">
                                            <div class="track-progress-line" style="width: 0%;" id="actualProgressLine"></div>
                                            <div class="track-step-item ${step >= 1 ? (step > 1 ? 'completed' : 'active') : ''}">
                                                <div class="track-step-circle">${step > 1 ? '✓' : '01'}</div>
                                                <div class="track-step-label">Registered</div>
                                            </div>
                                            <div class="track-step-item ${step >= 2 ? (step > 2 ? 'completed' : 'active') : ''}">
                                                <div class="track-step-circle">${step > 2 ? '✓' : '02'}</div>
                                                <div class="track-step-label">Assigned</div>
                                            </div>
                                            <div class="track-step-item ${step >= 3 ? 'active' : ''}">
                                                <div class="track-step-circle">${step === 3 ? '✓' : '03'}</div>
                                                <div class="track-step-label">Resolved</div>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    ${res.status === 'Resolved' && res.resolutionRemark ? `
                                        <div class="alert alert-success border-0 rounded-4 p-3 mb-3 shadow-sm">
                                            <div class="d-flex align-items-center mb-2">
                                                <span class="fs-5 me-2">📝</span>
                                                <h6 class="fw-bold mb-0">Resolution Remark</h6>
                                            </div>
                                            <p class="mb-0 small text-dark">${res.resolutionRemark}</p>
                                        </div>
                                    ` : ''}
                                    
                                    <div class="card bg-light border-0 rounded-4 p-3 mt-2">
                                        <div class="row text-center">
                                            <div class="col-6 border-end">
                                                <label class="text-muted small d-block mb-1">Category</label>
                                                <span class="fw-bold text-dark">${res.category}</span>
                                            </div>
                                            <div class="col-6">
                                                <label class="text-muted small d-block mb-1">Assigned To</label>
                                                <span class="fw-bold text-dark">${res.assignedTo}</span>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="text-center mt-4">
                                        <button class="btn btn-outline-secondary btn-sm rounded-pill px-4" onclick="location.reload()">Track Another</button>
                                    </div>
                                </div>
                            `);
                            
                            // Animate progress line
                            setTimeout(() => {
                                $('#actualProgressLine').css('width', `calc(${progressWidth}% - 0px)`);
                            }, 100);
                            
                            $('#trackForm').hide();
                        }
                    },
                    error: function(xhr) {
                        var msg = xhr.responseJSON ? xhr.responseJSON.message : "Complaint not found or system error.";
                        $result.html('<div class="alert alert-danger p-3 rounded-4 mb-4">' + msg + '</div>');
                    }
                });
            });

            // Clear modal on close
            $('#trackModal').on('hidden.bs.modal', function () {
                $('#trackId').val('');
                $('#trackResult').html('');
                $('#trackForm').show();
            });
        });
    </script>
}
